{
  "manifest_version": 3,
  "name": "Smart NID Helper",
  "version": "1.1",
  "description": "Seamlessly transfer data from Smart NID to the official DoNIDCR portal.",
  "icons": {
    "16": "icons/icon.png",
    "32": "icons/icon.png",
    "48": "icons/icon.png",
    "128": "icons/icon.png"
  },
  "action": {
    "default_title": "Smart NID Helper",
    "default_icon": {
      "16": "icons/icon.png",
      "32": "icons/icon.png",
      "48": "icons/icon.png",
      "128": "icons/icon.png"
    }
  },
  "permissions": [
    "storage",
    "tabs",
    "scripting"
  ],
  "host_permissions": [
    "*://enrollment.donidcr.gov.np/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "http://localhost:*/*",
        "http://127.0.0.1:*/*",
        "https://smart-nid-nepal.vercel.app/*"
      ],
      "js": ["content-app.js"]
    },
    {
      "matches": [
        "*://enrollment.donidcr.gov.np/*"
      ],
      "js": ["content-donidcr.js"],
      "run_at": "document_idle"
    }
  ]
}
