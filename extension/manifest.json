{
  "manifest_version": 3,
  "name": "Smart NID Helper",
  "version": "1.1.0",
  "description": "Seamlessly transfer data from Smart NID to the official DoNIDCR portal.",
  "offline_enabled": false,
  "icons": {
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "Smart NID Helper",
    "default_popup": "popup.html",
    "default_icon": {
      "128": "icons/icon128.png"
    }
  },
  "permissions": [
    "storage",
    "tabs",
    "scripting"
  ],
  "host_permissions": [
    "*://enrollment.donidcr.gov.np/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://smartnid.aadarshapandit.com.np/*",
        "https://smart-nid-nepal.vercel.app/*"
      ],
      "js": ["content-app.js"]
    },
    {
      "matches": [
        "*://enrollment.donidcr.gov.np/*"
      ],
      "js": ["content-donidcr.js"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["icons/guide.png"],
      "matches": ["*://enrollment.donidcr.gov.np/*"]
    }
  ]
}
